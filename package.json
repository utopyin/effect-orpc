{
  "name": "effect-orpc-workspace",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "bun run --cwd packages/effect-orpc build",
    "build:watch": "bun run --cwd packages/effect-orpc build:watch",
    "type:check": "bun run --cwd packages/effect-orpc type:check",
    "lint:check": "oxlint",
    "format:check": "oxfmt --check",
    "check": "bun run format:check && bun run lint:check && bun run type:check",
    "format": "oxfmt",
    "test": "bun run --cwd packages/effect-orpc test",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "bun run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "oxfmt": "^0.21.0",
    "oxlint": "^1.36.0",
    "ultracite": "7.0.3"
  }
}
