{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "build:watch": {
      "cache": false,
      "persistent": true
    },
    "type:check": {
      "dependsOn": ["^type:check"],
      "outputs": []
    },
    "test": {
      "outputs": []
    }
  }
}
